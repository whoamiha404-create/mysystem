# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Auth
# Change this before production. Use a long random string.
JWT_SECRET=change_this_to_a_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# First-run developer account
# Only one developer account is seeded automatically.
DEVELOPER_USER=developer
DEVELOPER_PASS=developer123

# First-run owner/admin account
ADMIN_USER=admin
ADMIN_PASS=admin123

# Business defaults
CURRENCY=USD
TIMEZONE=Asia/Baghdad

# Chrome path for whatsapp-web.js.
# Leave blank to auto-detect, or set the full path if needed on Windows/VPS.
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# SQLite database path
DB_PATH=./db/rentpro.db
